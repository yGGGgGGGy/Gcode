# Gcode 配置模板
# 复制为 .env 并修改

# === 推理层 LLM 配置 ===
# 可选: qwen, deepseek, claude, ollama
GCODE_LLM_PROVIDER=qwen

# Qwen API
GCODE_QWEN_API_KEY=your-api-key-here
GCODE_QWEN_MODEL=qwen-turbo

# DeepSeek API
GCODE_DEEPSEEK_API_KEY=your-api-key-here
GCODE_DEEPSEEK_MODEL=deepseek-chat

# Claude API
GCODE_CLAUDE_API_KEY=your-api-key-here
GCODE_CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (本地)
GCODE_OLLAMA_URL=http://localhost:11434
GCODE_OLLAMA_MODEL=qwen2.5:0.5b

# === 意图分类器 ===
GCODE_INTENT_MODEL=Qwen/Qwen2.5-0.5B
GCODE_SAFE_THRESHOLD=0.6
GCODE_REVIEW_THRESHOLD=0.4

# === Socket 路径 ===
GCODE_SOCKET_PATH=/run/gcode/gcode.sock
GCODE_DP1_SOCKET_PATH=/run/gcode/gcode-dp1.sock

# === 审计 ===
GCODE_AUDIT_DB=/opt/gcode/data/audit/gcode.db
GCODE_AUDIT_RETENTION_DAYS=90

# === HTTP API (可选) ===
GCODE_HTTP_ENABLED=false
GCODE_HTTP_HOST=127.0.0.1
GCODE_HTTP_PORT=9800
GCODE_HTTP_TOKEN=your-secret-token
